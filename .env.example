# =============================================================================
# Radar Brands — variáveis de ambiente (copie para .env e preencha)
# =============================================================================

NODE_ENV=development
APP_URL=http://localhost:3000
APP_NAME=radar-brands
PORT=3003

# MySQL (Prisma)
DATABASE_URL=mysql://USER:PASSWORD@HOST:3306/radarbrands
DIRECT_DATABASE_URL=mysql://USER:PASSWORD@HOST:3306/radarbrands

# Segurança (gere valores fortes — nunca commite o .env)
AUTH_SECRET=change-me-min-32-chars-random-string-here
ENCRYPTION_KEY=change-me-32-byte-base64-key-for-credentials

# Redis (opcional em dev; recomendado em produção)
REDIS_URL=redis://127.0.0.1:6379

# E-mail (organização via /dashboard/settings ou fallback de plataforma)
EMAIL_PROVIDER=smtp
EMAIL_FROM=noreply@radarbrands.com.br
EMAIL_REPLY_TO=suporte@radarbrands.com.br

# SMTP (fallback de plataforma quando org não tem config)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false

# API (fallback de plataforma)
RESEND_API_KEY=
MAILGUN_API_KEY=
MAILGUN_DOMAIN=

# Storage (fase posterior)
STORAGE_PROVIDER=local

# Worker de endpoints (cron de captura)
# ENDPOINTS_CRON_MS=15000
# ENDPOINTS_CRON_BATCH=15


# Públicas (expostas ao browser via VITE_)
VITE_APP_URL=http://localhost:3000
VITE_APP_NAME=Radar Brands
