// ---------- 15. Search endpoints (plataforma / admin) ----------

enum EndpointCategory {
  search
  social
  marketplace
  appstore
  darkweb
  domain
  news
  review
  video
  messaging
  ai
}

enum EndpointHealth {
  healthy
  degraded
  down
  paused
}

enum EndpointRunStatus {
  queued
  running
  done
  failed
  skipped
}

model PlatformSetting {
  id        Int      @id @default(autoincrement()) @db.UnsignedSmallInt
  key       String   @unique @db.VarChar(80)
  value     Json     @map("value_json")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("platform_settings")
}

model SearchEndpoint {
  id             BigInt          @id @default(autoincrement()) @db.UnsignedBigInt
  code           String          @unique @db.VarChar(80)
  name           String          @db.VarChar(120)
  category       EndpointCategory
  description    String          @map("description") @db.VarChar(512)
  baseUrl        String?         @map("base_url") @db.VarChar(1024)
  enabled        Boolean         @default(false)
  frequencyMin   Int             @default(30) @map("frequency_min") @db.UnsignedInt
  priority       Int             @default(2) @db.UnsignedTinyInt
  health         EndpointHealth  @default(paused)
  latencyMs      Int             @default(0) @map("latency_ms") @db.UnsignedInt
  successRate    Decimal         @default(100) @map("success_rate") @db.Decimal(5, 2)
  hits24h        Int             @default(0) @map("hits_24h") @db.UnsignedInt
  costPer1k      Decimal         @default(0) @map("cost_per_1k") @db.Decimal(10, 4)
  requiresKey    Boolean         @default(false) @map("requires_key")
  credentialsEnc String?         @map("credentials_enc") @db.Text
  region         String?         @db.VarChar(20)
  concurrency    Int             @default(3) @db.UnsignedTinyInt
  isCustom       Boolean         @default(false) @map("is_custom")
  tag            String?         @db.VarChar(40)
  advanced       Json?           @map("advanced_json")
  lastRunAt      DateTime?       @map("last_run_at")
  nextRunAt      DateTime?       @map("next_run_at")
  lastError      String?         @map("last_error") @db.VarChar(512)
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  runs SearchEndpointRun[]

  @@index([enabled, nextRunAt])
  @@index([category, enabled])
  @@map("search_endpoints")
}

model SearchEndpointRun {
  id           BigInt            @id @default(autoincrement()) @db.UnsignedBigInt
  endpointId   BigInt            @map("endpoint_id") @db.UnsignedBigInt
  status       EndpointRunStatus @default(queued)
  triggeredBy  String            @default("cron") @map("triggered_by") @db.VarChar(40)
  latencyMs    Int?              @map("latency_ms") @db.UnsignedInt
  itemsFound   Int               @default(0) @map("items_found") @db.UnsignedInt
  success      Boolean?
  error        String?           @db.VarChar(1024)
  meta         Json?             @map("meta_json")
  startedAt    DateTime?         @map("started_at")
  finishedAt   DateTime?         @map("finished_at")
  createdAt    DateTime          @default(now()) @map("created_at")

  endpoint SearchEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([endpointId, createdAt])
  @@index([status, createdAt])
  @@map("search_endpoint_runs")
}
