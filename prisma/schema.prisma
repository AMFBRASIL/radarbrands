// ---------- 1. Núcleo tenant / RBAC ----------

model Organization {
  id               BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  uuid             String   @unique @db.Char(36)
  legalName        String   @map("legal_name") @db.VarChar(255)
  tradeName        String?  @map("trade_name") @db.VarChar(255)
  slug             String   @unique @db.VarChar(120)
  taxId            String?  @map("tax_id") @db.VarChar(32)
  countryCode      String   @default("BR") @map("country_code") @db.Char(2)
  industry         String?  @db.VarChar(120)
  website          String?  @db.VarChar(255)
  logoUrl          String?  @map("logo_url") @db.VarChar(512)
  timezone         String   @default("America/Sao_Paulo") @db.VarChar(64)
  locale           String   @default("pt-BR") @db.VarChar(10)
  planTier         PlanTier @default(free) @map("plan_tier")
  status           OrgStatus @default(trial)
  trialEndsAt      DateTime? @map("trial_ends_at")
  settings         Json?     @map("settings_json")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt        @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  members          OrganizationMember[]
  brands           Brand[]
  apiKeys          ApiKey[]
  auditLog         AuditLog[]
  mentions         Mention[]
  threats          Threat[]
  alertRules       AlertRule[]
  alerts           Alert[]
  notifications    Notification[]
  takedowns        Takedown[]
  legalCases       LegalCase[]
  legalDocuments   LegalDocument[]
  playbooks        Playbook[]
  incidents        Incident[]
  aiConversations  AiConversation[]
  aiPredictions    AiPrediction[]
  reports          Report[]
  roiEvents        RoiEvent[]
  savedViews       SavedView[]
  onboarding       OnboardingProgress[]
  wrapped          WrappedReport[]
  subscription     Subscription?
  invoices         Invoice[]
  usageCounters    UsageCounter[]
  integrations     Integration[]
  webhookEndpoints WebhookEndpoint[]
  featureFlags     OrganizationFeatureFlag[]
  influencers      Influencer[]
  inviteTokens     UserInviteToken[]

  @@map("organizations")
}

model User {
  id               BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  uuid             String   @unique @db.Char(36)
  email            String   @unique @db.VarChar(255)
  emailVerifiedAt  DateTime? @map("email_verified_at")
  phone            String?  @db.VarChar(32)
  fullName         String   @map("full_name") @db.VarChar(180)
  displayName      String?  @map("display_name") @db.VarChar(120)
  avatarUrl        String?  @map("avatar_url") @db.VarChar(512)
  passwordHash     String?  @map("password_hash") @db.VarChar(255)
  passwordAlgo     String?  @map("password_algo") @db.VarChar(20)
  mfaEnabled       Boolean  @default(false) @map("mfa_enabled")
  locale           String   @default("pt-BR") @db.VarChar(10)
  timezone         String   @default("America/Sao_Paulo") @db.VarChar(64)
  lastLoginAt      DateTime? @map("last_login_at")
  status           UserStatus @default(invited)
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt        @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  identities       Identity[]
  sessions         Session[]
  memberships      OrganizationMember[]
  inviteTokens     UserInviteToken[]
  auditLog         AuditLog[]
  threatComments   ThreatComment[]
  assignedThreats  Threat[]      @relation("ThreatAssignee")
  assignedTakedowns Takedown[]   @relation("TakedownAssignee")
  ackAlerts        Alert[]       @relation("AlertAckBy")
  notifications    Notification[]
  incidentParticip IncidentParticipant[]
  aiConversations  AiConversation[]
  incidentSteps    IncidentStep[]
  savedViews       SavedView[]
  onboarding       OnboardingProgress[]
  incidentTimeline IncidentTimeline[]
  blogPosts        BlogPost[]

  @@map("users")
}

model Identity {
  id          BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  userId      BigInt   @map("user_id") @db.UnsignedBigInt
  provider    IdentityProvider
  providerUid String   @map("provider_uid") @db.VarChar(255)
  meta        Json?    @map("meta_json")
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUid], map: "uk_identity")
  @@index([userId])
  @@map("identities")
}

model Session {
  id          BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  userId      BigInt   @map("user_id") @db.UnsignedBigInt
  tokenHash   String   @unique @map("token_hash") @db.Char(64)
  userAgent   String?  @map("user_agent") @db.VarChar(512)
  deviceLabel String?  @map("device_label") @db.VarChar(120)
  expiresAt   DateTime @map("expires_at")
  revokedAt   DateTime? @map("revoked_at")
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@map("sessions")
}

model UserInviteToken {
  id             BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  userId         BigInt    @map("user_id") @db.UnsignedBigInt
  organizationId BigInt    @map("organization_id") @db.UnsignedBigInt
  tokenHash      String    @unique @map("token_hash") @db.Char(64)
  expiresAt      DateTime  @map("expires_at")
  usedAt         DateTime? @map("used_at")
  createdBy      BigInt?   @map("created_by") @db.UnsignedBigInt
  createdAt      DateTime  @default(now()) @map("created_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([userId, organizationId])
  @@index([expiresAt])
  @@map("user_invite_tokens")
}

model Role {
  id          Int      @id @default(autoincrement()) @db.UnsignedSmallInt
  code        String   @unique @db.VarChar(40)
  name        String   @db.VarChar(80)
  scope       RoleScope @default(org)
  description String?  @db.VarChar(255)

  permissions RolePermission[]
  members     OrganizationMember[]

  @@map("roles")
}

model Permission {
  id       Int    @id @default(autoincrement()) @db.UnsignedSmallInt
  code     String @unique @db.VarChar(80)
  category String @db.VarChar(40)

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       Int @map("role_id") @db.UnsignedSmallInt
  permissionId Int @map("permission_id") @db.UnsignedSmallInt

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model OrganizationMember {
  id             BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  organizationId BigInt   @map("organization_id") @db.UnsignedBigInt
  userId         BigInt   @map("user_id") @db.UnsignedBigInt
  roleId         Int      @map("role_id") @db.UnsignedSmallInt
  title          String?  @db.VarChar(120)
  invitedBy      BigInt?  @map("invited_by") @db.UnsignedBigInt
  invitedAt      DateTime? @map("invited_at")
  acceptedAt     DateTime? @map("accepted_at")
  status         MemberStatus @default(invited)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt        @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId],         references: [id], onDelete: Cascade)
  role         Role         @relation(fields: [roleId],         references: [id])

  @@unique([organizationId, userId])
  @@map("organization_members")
}

model ApiKey {
  id             BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  organizationId BigInt   @map("organization_id") @db.UnsignedBigInt
  name           String   @db.VarChar(120)
  prefix         String   @db.Char(8)
  keyHash        String   @unique @map("key_hash") @db.Char(64)
  scopes         Json     @map("scopes_json")
  lastUsedAt     DateTime? @map("last_used_at")
  expiresAt      DateTime? @map("expires_at")
  createdBy      BigInt?  @map("created_by") @db.UnsignedBigInt
  revokedAt      DateTime? @map("revoked_at")
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("api_keys")
}

model AuditLog {
  id             BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  organizationId BigInt?  @map("organization_id") @db.UnsignedBigInt
  actorUserId    BigInt?  @map("actor_user_id") @db.UnsignedBigInt
  actorType      ActorType @default(user) @map("actor_type")
  action         String   @db.VarChar(80)
  entityType     String   @map("entity_type") @db.VarChar(60)
  entityId       BigInt?  @map("entity_id") @db.UnsignedBigInt
  userAgent      String?  @map("user_agent") @db.VarChar(512)
  before         Json?    @map("before_json")
  after          Json?    @map("after_json")
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actor        User?         @relation(fields: [actorUserId],    references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([entityType, entityId])
  @@map("audit_log")
}

// ---------- 2. Brands ----------

model Brand {
  id              BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  uuid            String   @unique @db.Char(36)
  organizationId  BigInt   @map("organization_id") @db.UnsignedBigInt
  name            String   @db.VarChar(180)
  slug            String   @db.VarChar(120)
  officialDomain  String?  @map("official_domain") @db.VarChar(255)
  aliases         Json?    @map("aliases_json")
  colorPrimary    String?  @map("color_primary") @db.Char(9)
  logoUrl         String?  @map("logo_url") @db.VarChar(512)
  industry        String?  @db.VarChar(120)
  isPrimary       Boolean  @default(false) @map("is_primary")
  status          BrandStatus @default(active)
  healthScore     Decimal  @default(0) @map("health_score") @db.Decimal(5,2)
  healthUpdatedAt DateTime? @map("health_updated_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt        @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  keywords        BrandKeyword[]
  assets          BrandAsset[]
  trademarks      Trademark[]
  sourceConfigs   BrandSourceConfig[]
  crawlJobs       CrawlJob[]
  mentions        Mention[]
  threats         Threat[]
  alertRules      AlertRule[]
  alerts          Alert[]
  legalCases      LegalCase[]
  incidents       Incident[]
  aiConversations AiConversation[]
  aiPredictions   AiPrediction[]
  healthSnapshots BrandHealthSnapshot[]
  reports         Report[]
  roiEvents       RoiEvent[]
  wrapped         WrappedReport[]
  competitors     Competitor[]
  influencers     Influencer[]

  @@unique([organizationId, slug])
  @@map("brands")
}

model BrandKeyword {
  id         BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  brandId    BigInt   @map("brand_id") @db.UnsignedBigInt
  keyword    String   @db.VarChar(255)
  kind       KeywordKind @default(phrase)
  language   String?  @db.VarChar(10)
  weight     Int      @default(5) @db.UnsignedTinyInt
  isNegative Boolean  @default(false) @map("is_negative")
  createdAt  DateTime @default(now()) @map("created_at")

  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@unique([brandId, keyword, kind])
  @@map("brand_keywords")
}

model BrandAsset {
  id              BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  brandId         BigInt   @map("brand_id") @db.UnsignedBigInt
  kind            AssetKind
  url             String   @db.VarChar(1024)
  hashPerceptual  String?  @map("hash_perceptual") @db.VarChar(64)
  meta            Json?    @map("meta_json")
  createdAt       DateTime @default(now()) @map("created_at")

  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@index([hashPerceptual])
  @@map("brand_assets")
}

model Trademark {
  id             BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  brandId        BigInt   @map("brand_id") @db.UnsignedBigInt
  registry       String   @db.VarChar(20)
  registrationNo String   @map("registration_no") @db.VarChar(80)
  classNice      String   @map("class_nice") @db.VarChar(100)
  status         TrademarkStatus
  filedAt        DateTime? @map("filed_at") @db.Date
  grantedAt      DateTime? @map("granted_at") @db.Date
  expiresAt      DateTime? @map("expires_at") @db.Date
  jurisdiction   String   @default("BR") @db.Char(2)
  ownerName      String?  @map("owner_name") @db.VarChar(255)
  documentUrl    String?  @map("document_url") @db.VarChar(1024)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt        @map("updated_at")

  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@unique([registry, registrationNo, jurisdiction])
  @@map("trademarks")
}

// ---------- 3. Monitoring ----------

model MonitoringSource {
  id        Int    @id @default(autoincrement()) @db.UnsignedSmallInt
  code      String @unique @db.VarChar(40)
  name      String @db.VarChar(80)
  category  SourceCategory
  icon      String? @db.VarChar(60)
  isEnabled Boolean @default(true) @map("is_enabled")

  brandConfigs BrandSourceConfig[]
  crawlJobs    CrawlJob[]
  mentions     Mention[]
  threats      Threat[]

  @@map("monitoring_sources")
}

model BrandSourceConfig {
  id          BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  brandId     BigInt   @map("brand_id") @db.UnsignedBigInt
  sourceId    Int      @map("source_id") @db.UnsignedSmallInt
  isEnabled   Boolean  @default(true) @map("is_enabled")
  pollSeconds Int      @default(900) @map("poll_seconds") @db.UnsignedInt
  config      Json?    @map("config_json")
  lastRunAt   DateTime? @map("last_run_at")
  nextRunAt   DateTime? @map("next_run_at")
  lastStatus  SourceStatus? @map("last_status")
  lastError   String?  @map("last_error") @db.VarChar(512)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt        @map("updated_at")

  brand  Brand            @relation(fields: [brandId],  references: [id], onDelete: Cascade)
  source MonitoringSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([brandId, sourceId])
  @@index([nextRunAt])
  @@map("brand_source_configs")
}

model CrawlJob {
  id            BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  brandId       BigInt   @map("brand_id") @db.UnsignedBigInt
  sourceId      Int      @map("source_id") @db.UnsignedSmallInt
  status        CrawlStatus @default(queued)
  attempts      Int      @default(0) @db.UnsignedTinyInt
  scheduledAt   DateTime @map("scheduled_at")
  startedAt     DateTime? @map("started_at")
  finishedAt    DateTime? @map("finished_at")
  itemsFound    Int      @default(0) @map("items_found") @db.UnsignedInt
  error         String?  @db.VarChar(1024)
  meta          Json?    @map("meta_json")
  createdAt     DateTime @default(now()) @map("created_at")

  brand  Brand            @relation(fields: [brandId],  references: [id], onDelete: Cascade)
  source MonitoringSource @relation(fields: [sourceId], references: [id])

  @@index([status, scheduledAt])
  @@index([brandId, createdAt])
  @@map("crawl_jobs")
}

model Mention {
  id              BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  uuid            String   @unique @db.Char(36)
  organizationId  BigInt   @map("organization_id") @db.UnsignedBigInt
  brandId         BigInt   @map("brand_id") @db.UnsignedBigInt
  sourceId        Int      @map("source_id") @db.UnsignedSmallInt
  externalId      String?  @map("external_id") @db.VarChar(191)
  url             String?  @db.VarChar(1024)
  authorHandle    String?  @map("author_handle") @db.VarChar(191)
  authorUrl       String?  @map("author_url") @db.VarChar(512)
  authorFollowers Int?     @map("author_followers") @db.UnsignedInt
  language        String?  @db.VarChar(10)
  title           String?  @db.VarChar(512)
  content         String?  @db.MediumText
  contentHash     String   @map("content_hash") @db.Char(64)
  sentiment       Sentiment?
  sentimentScore  Decimal? @map("sentiment_score") @db.Decimal(4,3)
  reachEstimate   Int?     @map("reach_estimate") @db.UnsignedInt
  engagement      Int?     @db.UnsignedInt
  isCrisisSignal  Boolean  @default(false) @map("is_crisis_signal")
  detectedAt      DateTime @map("detected_at")
  publishedAt     DateTime? @map("published_at")
  raw             Json?    @map("raw_json")
  createdAt       DateTime @default(now()) @map("created_at")

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  brand        Brand           @relation(fields: [brandId],        references: [id], onDelete: Cascade)
  source       MonitoringSource @relation(fields: [sourceId],      references: [id])
  threats      Threat[]

  @@unique([brandId, sourceId, contentHash])
  @@index([organizationId, detectedAt])
  @@index([brandId, detectedAt])
  @@map("mentions")
}

// ---------- 4. Threats + specialized findings ----------

model Threat {
  id                 BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  uuid               String   @unique @db.Char(36)
  organizationId     BigInt   @map("organization_id") @db.UnsignedBigInt
  brandId            BigInt   @map("brand_id") @db.UnsignedBigInt
  category           ThreatCategory
  sourceId           Int?     @map("source_id") @db.UnsignedSmallInt
  mentionId          BigInt?  @map("mention_id") @db.UnsignedBigInt
  title              String   @db.VarChar(300)
  description        String?  @db.Text
  url                String?  @db.VarChar(1024)
  severity           Severity @default(medium)
  riskScore          Decimal  @default(0) @map("risk_score") @db.Decimal(5,2)
  status             ThreatStatus @default(new)
  assignedTo         BigInt?  @map("assigned_to") @db.UnsignedBigInt
  evidence           Json?    @map("evidence_json")
  firstSeenAt        DateTime @map("first_seen_at")
  lastSeenAt         DateTime @map("last_seen_at")
  resolvedAt         DateTime? @map("resolved_at")
  estimatedLossBrl   Decimal? @map("estimated_loss_brl") @db.Decimal(14,2)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt        @map("updated_at")
  deletedAt          DateTime? @map("deleted_at")

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  brand        Brand             @relation(fields: [brandId],        references: [id], onDelete: Cascade)
  source       MonitoringSource? @relation(fields: [sourceId],       references: [id])
  mention      Mention?          @relation(fields: [mentionId],      references: [id], onDelete: SetNull)
  assignee     User?             @relation("ThreatAssignee", fields: [assignedTo], references: [id], onDelete: SetNull)

  evidenceItems ThreatEvidence[]
  comments      ThreatComment[]
  domain        DomainFinding?
  ads           AdFinding[]
  social        SocialFinding?
  marketplace   MarketplaceFinding[]
  deepfakes     DeepfakeFinding[]
  darkweb       DarkwebFinding[]
  alerts        Alert[]
  takedowns     Takedown[]
  legalDocs     LegalDocument[]
  playbookRuns  PlaybookRun[]
  roiEvents     RoiEvent[]

  @@index([organizationId, status, severity])
  @@index([brandId, category, status])
  @@index([assignedTo, status])
  @@index([firstSeenAt])
  @@map("threats")
}

model ThreatEvidence {
  id         BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  threatId   BigInt   @map("threat_id") @db.UnsignedBigInt
  kind       EvidenceKind
  url        String   @db.VarChar(1024)
  sha256     String?  @db.Char(64)
  capturedAt DateTime @default(now()) @map("captured_at")
  meta       Json?    @map("meta_json")

  threat Threat @relation(fields: [threatId], references: [id], onDelete: Cascade)

  @@map("threat_evidence")
}

model ThreatComment {
  id        BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  threatId  BigInt   @map("threat_id") @db.UnsignedBigInt
  userId    BigInt?  @map("user_id") @db.UnsignedBigInt
  isAi      Boolean  @default(false) @map("is_ai")
  body      String   @db.MediumText
  createdAt DateTime @default(now()) @map("created_at")

  threat Threat @relation(fields: [threatId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId],   references: [id], onDelete: SetNull)

  @@index([threatId, createdAt])
  @@map("threat_comments")
}

model DomainFinding {
  id             BigInt @id @default(autoincrement()) @db.UnsignedBigInt
  threatId       BigInt @unique @map("threat_id") @db.UnsignedBigInt
  domain         String @db.VarChar(255)
  tld            String @db.VarChar(20)
  registrar      String? @db.VarChar(120)
  registeredAt   DateTime? @map("registered_at") @db.Date
  expiresAt      DateTime? @map("expires_at") @db.Date
  nsRecords      Json?  @map("ns_records")
  aRecords       Json?  @map("a_records")
  mxRecords      Json?  @map("mx_records")
  whois          Json?  @map("whois_json")
  similarity     Decimal? @db.Decimal(4,3)
  hasMx          Boolean @default(false) @map("has_mx")
  hasSsl         Boolean @default(false) @map("has_ssl")
  sslIssuer      String? @map("ssl_issuer") @db.VarChar(255)
  screenshotUrl  String? @map("screenshot_url") @db.VarChar(1024)

  threat Threat @relation(fields: [threatId], references: [id], onDelete: Cascade)

  @@index([domain])
  @@map("domain_findings")
}

model AdFinding {
  id            BigInt @id @default(autoincrement()) @db.UnsignedBigInt
  threatId      BigInt @map("threat_id") @db.UnsignedBigInt
  network       AdNetwork
  advertiser    String? @db.VarChar(255)
  keyword       String? @db.VarChar(255)
  landingUrl    String? @map("landing_url") @db.VarChar(1024)
  adCopy        String? @map("ad_copy") @db.Text
  firstSeenAt   DateTime @map("first_seen_at")
  activeDays    Int      @default(0) @map("active_days") @db.UnsignedInt
  spendEstimate Decimal? @map("spend_estimate") @db.Decimal(12,2)
  region        String? @db.VarChar(80)
  screenshotUrl String? @map("screenshot_url") @db.VarChar(1024)

  threat Threat @relation(fields: [threatId], references: [id], onDelete: Cascade)

  @@index([threatId])
  @@index([advertiser])
  @@map("ad_findings")
}

model SocialFinding {
  id              BigInt @id @default(autoincrement()) @db.UnsignedBigInt
  threatId        BigInt @unique @map("threat_id") @db.UnsignedBigInt
  network         SocialNetwork
  handle          String @db.VarChar(120)
  profileUrl      String @map("profile_url") @db.VarChar(1024)
  followers       Int?   @db.UnsignedInt
  isVerifiedFake  Boolean @default(false) @map("is_verified_fake")
  postsCount      Int?   @map("posts_count") @db.UnsignedInt
  similarity      Decimal? @db.Decimal(4,3)
  bio             String? @db.Text

  threat Threat @relation(fields: [threatId], references: [id], onDelete: Cascade)

  @@index([network, handle])
  @@map("social_findings")
}

model MarketplaceFinding {
  id                     BigInt @id @default(autoincrement()) @db.UnsignedBigInt
  threatId               BigInt @map("threat_id") @db.UnsignedBigInt
  marketplace            Marketplace
  seller                 String? @db.VarChar(255)
  listingId              String? @map("listing_id") @db.VarChar(120)
  title                  String? @db.VarChar(512)
  price                  Decimal? @db.Decimal(12,2)
  currency               String?  @db.Char(3)
  stock                  Int?
  isCounterfeit          Boolean @default(false) @map("is_counterfeit")
  isUnauthorizedReseller Boolean @default(false) @map("is_unauthorized_reseller")
  screenshotUrl          String? @map("screenshot_url") @db.VarChar(1024)

  threat Threat @relation(fields: [threatId], references: [id], onDelete: Cascade)

  @@index([threatId])
  @@index([marketplace, seller])
  @@map("marketplace_findings")
}

model DeepfakeFinding {
  id             BigInt @id @default(autoincrement()) @db.UnsignedBigInt
  threatId       BigInt @map("threat_id") @db.UnsignedBigInt
  mediaKind      DeepfakeMedia @map("media_kind")
  mediaUrl       String @map("media_url") @db.VarChar(1024)
  detectedPerson String? @map("detected_person") @db.VarChar(255)
  confidence     Decimal @db.Decimal(4,3)
  modelUsed      String? @map("model_used") @db.VarChar(80)
  frames         Json?  @map("frames_json")
  audioFeatures  Json?  @map("audio_features_json")

  threat Threat @relation(fields: [threatId], references: [id], onDelete: Cascade)

  @@index([threatId])
  @@map("deepfake_findings")
}

model DarkwebFinding {
  id            BigInt @id @default(autoincrement()) @db.UnsignedBigInt
  threatId      BigInt @map("threat_id") @db.UnsignedBigInt
  sourceName    String @map("source_name") @db.VarChar(120)
  onionUrl      String? @map("onion_url") @db.VarChar(512)
  actor         String? @db.VarChar(120)
  leakType      LeakType @map("leak_type")
  sampleHash    String? @map("sample_hash") @db.Char(64)
  recordsCount  Int?   @map("records_count") @db.UnsignedInt
  priceBtc      Decimal? @map("price_btc") @db.Decimal(18,8)
  firstPostedAt DateTime? @map("first_posted_at")

  threat Threat @relation(fields: [threatId], references: [id], onDelete: Cascade)

  @@index([threatId])
  @@map("darkweb_findings")
}

model Influencer {
  id              BigInt @id @default(autoincrement()) @db.UnsignedBigInt
  organizationId  BigInt @map("organization_id") @db.UnsignedBigInt
  brandId         BigInt? @map("brand_id") @db.UnsignedBigInt
  handle          String @db.VarChar(120)
  network         InfluencerNet
  followers       Int?   @db.UnsignedInt
  engagementRate  Decimal? @map("engagement_rate") @db.Decimal(5,2)
  relationship    InfluencerRel @default(organic)
  meta            Json?  @map("meta_json")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt        @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  brand        Brand?       @relation(fields: [brandId],        references: [id], onDelete: SetNull)

  @@unique([organizationId, network, handle])
  @@map("influencers")
}

model Competitor {
  id        BigInt @id @default(autoincrement()) @db.UnsignedBigInt
  brandId   BigInt @map("brand_id") @db.UnsignedBigInt
  name      String @db.VarChar(180)
  website   String? @db.VarChar(255)
  aliases   Json?  @map("aliases_json")
  notes     String? @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@unique([brandId, name])
  @@map("competitors")
}

// ---------- 5. Alerts / notifications ----------

model AlertRule {
  id              BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  organizationId  BigInt   @map("organization_id") @db.UnsignedBigInt
  brandId         BigInt?  @map("brand_id") @db.UnsignedBigInt
  name            String   @db.VarChar(180)
  description     String?  @db.Text
  trigger         Json     @map("trigger_json")
  channels        Json     @map("channels_json")
  isEnabled       Boolean  @default(true) @map("is_enabled")
  cooldownSeconds Int      @default(300) @map("cooldown_seconds") @db.UnsignedInt
  createdBy       BigInt?  @map("created_by") @db.UnsignedBigInt
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt        @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  brand        Brand?       @relation(fields: [brandId],        references: [id], onDelete: Cascade)
  alerts       Alert[]

  @@index([organizationId, isEnabled])
  @@map("alert_rules")
}

model Alert {
  id             BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  uuid           String   @unique @db.Char(36)
  organizationId BigInt   @map("organization_id") @db.UnsignedBigInt
  brandId        BigInt   @map("brand_id") @db.UnsignedBigInt
  ruleId         BigInt?  @map("rule_id") @db.UnsignedBigInt
  threatId       BigInt?  @map("threat_id") @db.UnsignedBigInt
  severity       Severity
  title          String   @db.VarChar(300)
  body           String?  @db.Text
  status         AlertStatus @default(new)
  ackBy          BigInt?  @map("ack_by") @db.UnsignedBigInt
  ackAt          DateTime? @map("ack_at")
  snoozeUntil    DateTime? @map("snooze_until")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt        @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  brand        Brand        @relation(fields: [brandId],        references: [id], onDelete: Cascade)
  rule         AlertRule?   @relation(fields: [ruleId],         references: [id], onDelete: SetNull)
  threat       Threat?      @relation(fields: [threatId],       references: [id], onDelete: SetNull)
  ackByUser    User?        @relation("AlertAckBy", fields: [ackBy], references: [id], onDelete: SetNull)
  notifications Notification[]
  playbookRuns  PlaybookRun[]

  @@index([organizationId, status, severity])
  @@index([brandId, createdAt])
  @@map("alerts")
}

model Notification {
  id              BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  userId          BigInt   @map("user_id") @db.UnsignedBigInt
  organizationId  BigInt   @map("organization_id") @db.UnsignedBigInt
  alertId         BigInt?  @map("alert_id") @db.UnsignedBigInt
  channel         NotifChannel
  title           String   @db.VarChar(255)
  body            String?  @db.Text
  linkUrl         String?  @map("link_url") @db.VarChar(1024)
  isRead          Boolean  @default(false) @map("is_read")
  readAt          DateTime? @map("read_at")
  deliveryStatus  DeliveryStatus @default(queued) @map("delivery_status")
  deliveryError   String?  @map("delivery_error") @db.VarChar(512)
  createdAt       DateTime @default(now()) @map("created_at")

  user         User         @relation(fields: [userId],         references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  alert        Alert?       @relation(fields: [alertId],        references: [id], onDelete: SetNull)

  @@index([userId, isRead, createdAt])
  @@index([alertId])
  @@map("notifications")
}

// ---------- 6. Takedowns / legal / playbooks ----------

model Takedown {
  id             BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  uuid           String   @unique @db.Char(36)
  organizationId BigInt   @map("organization_id") @db.UnsignedBigInt
  threatId       BigInt   @map("threat_id") @db.UnsignedBigInt
  channel        TakedownChannel
  target         String   @db.VarChar(512)
  method         TakedownMethod
  status         TakedownStatus @default(draft)
  submittedAt    DateTime? @map("submitted_at")
  respondedAt    DateTime? @map("responded_at")
  removedAt      DateTime? @map("removed_at")
  referenceNo    String?  @map("reference_no") @db.VarChar(120)
  requestBody    String?  @map("request_body") @db.MediumText
  responseBody   String?  @map("response_body") @db.MediumText
  assignedTo     BigInt?  @map("assigned_to") @db.UnsignedBigInt
  costBrl        Decimal? @map("cost_brl") @db.Decimal(12,2)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt        @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  threat       Threat       @relation(fields: [threatId],       references: [id], onDelete: Cascade)
  assignee     User?        @relation("TakedownAssignee", fields: [assignedTo], references: [id], onDelete: SetNull)
  roiEvents    RoiEvent[]

  @@index([organizationId, status])
  @@index([threatId])
  @@map("takedowns")
}

model LegalCase {
  id             BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  organizationId BigInt   @map("organization_id") @db.UnsignedBigInt
  brandId        BigInt   @map("brand_id") @db.UnsignedBigInt
  caseType       LegalCaseType @map("case_type")
  title          String   @db.VarChar(255)
  status         LegalCaseStatus @default(draft)
  jurisdiction   String?  @db.Char(2)
  caseNo         String?  @map("case_no") @db.VarChar(120)
  counterparty   String?  @db.VarChar(255)
  lawFirm        String?  @map("law_firm") @db.VarChar(255)
  openedAt       DateTime? @map("opened_at") @db.Date
  closedAt       DateTime? @map("closed_at") @db.Date
  costBrl        Decimal? @map("cost_brl") @db.Decimal(14,2)
  summary        String?  @db.Text
  aiDraft        Json?    @map("ai_draft_json")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt        @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  brand        Brand        @relation(fields: [brandId],        references: [id], onDelete: Cascade)
  documents    LegalDocument[]

  @@index([organizationId, status])
  @@map("legal_cases")
}

model LegalDocument {
  id             BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  caseId         BigInt?  @map("case_id") @db.UnsignedBigInt
  threatId       BigInt?  @map("threat_id") @db.UnsignedBigInt
  organizationId BigInt   @map("organization_id") @db.UnsignedBigInt
  kind           LegalDocKind
  title          String   @db.VarChar(255)
  fileUrl        String   @map("file_url") @db.VarChar(1024)
  sha256         String?  @db.Char(64)
  generatedBy    LegalDocGenBy @default(human) @map("generated_by")
  version        Int      @default(1) @db.UnsignedSmallInt
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  case         LegalCase?   @relation(fields: [caseId],         references: [id], onDelete: Cascade)
  threat       Threat?      @relation(fields: [threatId],       references: [id], onDelete: SetNull)

  @@map("legal_documents")
}

model Playbook {
  id             BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  organizationId BigInt?  @map("organization_id") @db.UnsignedBigInt
  name           String   @db.VarChar(180)
  description    String?  @db.Text
  trigger        Json     @map("trigger_json")
  steps          Json     @map("steps_json")
  isAutopilot    Boolean  @default(false) @map("is_autopilot")
  isEnabled      Boolean  @default(true) @map("is_enabled")
  createdBy      BigInt?  @map("created_by") @db.UnsignedBigInt
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt        @map("updated_at")

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  runs         PlaybookRun[]

  @@index([organizationId, isEnabled])
  @@map("playbooks")
}

model PlaybookRun {
  id           BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  playbookId   BigInt   @map("playbook_id") @db.UnsignedBigInt
  threatId     BigInt?  @map("threat_id") @db.UnsignedBigInt
  alertId      BigInt?  @map("alert_id") @db.UnsignedBigInt
  triggeredBy  PlaybookTrigger @map("triggered_by")
  status       PlaybookRunStat @default(running)
  stepState    Json?    @map("step_state_json")
  startedAt    DateTime @default(now()) @map("started_at")
  finishedAt   DateTime? @map("finished_at")
  error        String?  @db.VarChar(1024)

  playbook Playbook @relation(fields: [playbookId], references: [id], onDelete: Cascade)
  threat   Threat?  @relation(fields: [threatId],   references: [id], onDelete: SetNull)
  alert    Alert?   @relation(fields: [alertId],    references: [id], onDelete: SetNull)

  @@index([playbookId, startedAt])
  @@map("playbook_runs")
}

// ---------- 7. War Room ----------

model Incident {
  id                  BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  uuid                String   @unique @db.Char(36)
  organizationId      BigInt   @map("organization_id") @db.UnsignedBigInt
  brandId             BigInt   @map("brand_id") @db.UnsignedBigInt
  code                String   @db.VarChar(20)
  title               String   @db.VarChar(300)
  description         String?  @db.Text
  severityIndex       Decimal  @default(0) @map("severity_index") @db.Decimal(5,2)
  status              IncidentStatus @default(open)
  sentimentScore      Decimal? @map("sentiment_score") @db.Decimal(4,3)
  mentionsDeltaPct    Decimal? @map("mentions_delta_pct") @db.Decimal(6,2)
  slaSeconds          Int      @default(900) @map("sla_seconds") @db.UnsignedInt
  slaStartedAt        DateTime? @map("sla_started_at")
  slaFirstResponseAt  DateTime? @map("sla_first_response_at")
  openedAt            DateTime @default(now()) @map("opened_at")
  resolvedAt          DateTime? @map("resolved_at")
  postMortemUrl       String?  @map("post_mortem_url") @db.VarChar(1024)
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt        @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  brand        Brand        @relation(fields: [brandId],        references: [id], onDelete: Cascade)
  participants IncidentParticipant[]
  steps        IncidentStep[]
  timeline     IncidentTimeline[]

  @@unique([organizationId, code])
  @@index([organizationId, status])
  @@map("incidents")
}

model IncidentParticipant {
  id         BigInt @id @default(autoincrement()) @db.UnsignedBigInt
  incidentId BigInt @map("incident_id") @db.UnsignedBigInt
  userId     BigInt @map("user_id") @db.UnsignedBigInt
  roleLabel  String? @map("role_label") @db.VarChar(80)
  presence   ParticipantPres @default(on)
  joinedAt   DateTime @default(now()) @map("joined_at")
  leftAt     DateTime? @map("left_at")

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId],     references: [id], onDelete: Cascade)

  @@unique([incidentId, userId])
  @@map("incident_participants")
}

model IncidentStep {
  id         BigInt @id @default(autoincrement()) @db.UnsignedBigInt
  incidentId BigInt @map("incident_id") @db.UnsignedBigInt
  ord        Int    @db.UnsignedSmallInt
  label      String @db.VarChar(255)
  isDone     Boolean @default(false) @map("is_done")
  doneBy     BigInt? @map("done_by") @db.UnsignedBigInt
  doneAt     DateTime? @map("done_at")

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  user     User?    @relation(fields: [doneBy],     references: [id], onDelete: SetNull)

  @@unique([incidentId, ord])
  @@map("incident_steps")
}

model IncidentTimeline {
  id           BigInt @id @default(autoincrement()) @db.UnsignedBigInt
  incidentId   BigInt @map("incident_id") @db.UnsignedBigInt
  actorUserId  BigInt? @map("actor_user_id") @db.UnsignedBigInt
  eventType    String @map("event_type") @db.VarChar(60)
  body         String? @db.Text
  meta         Json?  @map("meta_json")
  createdAt    DateTime @default(now()) @map("created_at")

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  actor    User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([incidentId, createdAt])
  @@map("incident_timeline")
}

// ---------- 8. AI / Predict ----------

model AiConversation {
  id             BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  organizationId BigInt   @map("organization_id") @db.UnsignedBigInt
  userId         BigInt?  @map("user_id") @db.UnsignedBigInt
  brandId        BigInt?  @map("brand_id") @db.UnsignedBigInt
  title          String?  @db.VarChar(255)
  contextKind    AiContextKind @default(global) @map("context_kind")
  contextRefId   BigInt?  @map("context_ref_id") @db.UnsignedBigInt
  model          String   @default("gpt-5") @db.VarChar(80)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt        @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId],         references: [id], onDelete: SetNull)
  brand        Brand?       @relation(fields: [brandId],        references: [id], onDelete: SetNull)
  messages     AiMessage[]

  @@index([organizationId, userId, updatedAt])
  @@map("ai_conversations")
}

model AiMessage {
  id             BigInt @id @default(autoincrement()) @db.UnsignedBigInt
  conversationId BigInt @map("conversation_id") @db.UnsignedBigInt
  role           AiRole
  content        String? @db.MediumText
  toolCalls      Json?   @map("tool_calls_json")
  tokensIn       Int?    @map("tokens_in") @db.UnsignedInt
  tokensOut      Int?    @map("tokens_out") @db.UnsignedInt
  costUsd        Decimal? @map("cost_usd") @db.Decimal(10,6)
  createdAt      DateTime @default(now()) @map("created_at")

  conversation AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

