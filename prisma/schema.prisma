  updatedAt              DateTime @updatedAt        @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan         Plan         @relation(fields: [planId],         references: [id])
  invoices     Invoice[]

  @@map("subscriptions")
}

model Invoice {
  id                BigInt @id @default(autoincrement()) @db.UnsignedBigInt
  organizationId    BigInt @map("organization_id") @db.UnsignedBigInt
  subscriptionId    BigInt? @map("subscription_id") @db.UnsignedBigInt
  number            String @db.VarChar(60)
  amountBrl         Decimal @map("amount_brl") @db.Decimal(12,2)
  taxBrl            Decimal @default(0) @map("tax_brl") @db.Decimal(12,2)
  currency          String @default("BRL") @db.Char(3)
  status            InvoiceStatus @default(open)
  provider          String @db.VarChar(20)
  providerInvoiceId String? @map("provider_invoice_id") @db.VarChar(120)
  hostedUrl         String? @map("hosted_url") @db.VarChar(1024)
  issuedAt          DateTime @map("issued_at")
  dueAt             DateTime? @map("due_at")
  paidAt            DateTime? @map("paid_at")
  items             Json?  @map("items_json")

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  payments     Payment[]

  @@unique([organizationId, number])
  @@index([organizationId, status])
  @@map("invoices")
}

model Payment {
  id              BigInt @id @default(autoincrement()) @db.UnsignedBigInt
  invoiceId       BigInt @map("invoice_id") @db.UnsignedBigInt
  method          PaymentMethod
  status          PaymentStatus
  amountBrl       Decimal @map("amount_brl") @db.Decimal(12,2)
  providerTxnId   String? @map("provider_txn_id") @db.VarChar(120)
  paidAt          DateTime? @map("paid_at")
  raw             Json?  @map("raw_json")
  createdAt       DateTime @default(now()) @map("created_at")

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("payments")
}

model UsageCounter {
