// =====================================================================
// Radar | brands — Prisma Schema (MySQL)
// Espelho 1:1 do radar_brands_schema.sql
// Rode: npx prisma generate  |  npx prisma migrate dev
// =====================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

