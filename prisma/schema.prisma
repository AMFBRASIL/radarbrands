  isPublic               Boolean @default(true) @map("is_public")

  subscriptions Subscription[]

  @@map("plans")
}

model Subscription {
  id                     BigInt @id @default(autoincrement()) @db.UnsignedBigInt
  organizationId         BigInt @unique @map("organization_id") @db.UnsignedBigInt
  planId                 Int    @map("plan_id") @db.UnsignedSmallInt
